[sub_resource type="Shader" id="Shader_iridescent"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

void fragment() {
    float fresnel = pow(1.0 - dot(NORMAL, VIEW), 2.0);
    ALBEDO = vec3(0.8, 0.9, 1.0);
    ALPHA = fresnel * 0.4;
    ROUGHNESS = 0.01;
    METALLIC = 0.1;
    vec3 rainbow = 0.5 + 0.5 * cos(6.28318 * (vec3(0.0, 0.33, 0.67) + fresnel));
    EMISSION = rainbow * fresnel * 0.6;
}"

