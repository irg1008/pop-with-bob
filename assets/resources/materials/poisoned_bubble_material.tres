[gd_resource type="ShaderMaterial" format=3 uid="uid://dw262on7dufqb"]

[sub_resource type="Shader" id="Shader_liub8"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

void fragment() {
    float ndotv = max(dot(NORMAL, VIEW), 0.0);
    float fresnel = pow(1.0 - ndotv, 2.4);
    float pulse = 0.5 + 0.5 * sin(TIME * 2.1);
    float swirl = 0.5 + 0.5 * sin((UV.x + UV.y) * 20.0 + TIME * 1.8 + NORMAL.y * 4.0);
    float veins = smoothstep(0.55, 0.95, 0.5 + 0.5 * sin(UV.x * 44.0 - UV.y * 36.0 + TIME * 2.6));

    vec3 poison_purple = vec3(0.42, 0.07, 0.56);
    vec3 poison_green = vec3(0.26, 0.95, 0.26);
    vec3 poison_mix = mix(poison_purple, poison_green, swirl * 0.75 + veins * 0.25);

    ALBEDO = poison_mix * 0.45 + vec3(0.03, 0.02, 0.04);
    ALPHA = clamp(0.2 + fresnel * 0.55 + veins * 0.1, 0.0, 0.9);
    ROUGHNESS = 0.03;
    METALLIC = 0.06;

    vec3 rim_tint = mix(vec3(0.65, 0.22, 0.82), vec3(0.38, 1.0, 0.28), swirl);
    EMISSION = rim_tint * (fresnel * 1.25 + veins * 0.35 + pulse * 0.2) * 0.95;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_liub8")
